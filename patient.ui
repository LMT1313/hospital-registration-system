}

/* 选中的项（包括有焦点和没焦点的情况） */
QListWidget::item:selected, 
QListWidget::item:selected:active, 
QListWidget::item:selected:!active {
    background-color: #000000;
    color: #ffffff;
    border: none;
}

/* 鼠标悬停但未选中（可选，增加交互感） */
